rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.role == 'admin';
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // `x in data.players` still THROWS if `players` isn't present on `data`
    // at all (not just if the key is missing) — a fresh room doc may not
    // have a `players` field yet at all. Always check field presence first.
    function hasPlayer(data, uid) {
      return 'players' in data && uid in data.players;
    }

    function isRoomParticipant(roomId) {
      return isAuth()
        && roomId != null
        && exists(/databases/$(database)/documents/rooms/$(roomId))
        && hasPlayer(get(/databases/$(database)/documents/rooms/$(roomId)).data, request.auth.uid);
    }

    // ── Collection: maps ──────────────────────────────────────────────
    match /maps/{mapId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Collection: regions ────────────────────────────────────────────
    match /regions/{regionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Collection: topics ───────────────────────────────────────────
    match /topics/{topicId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Collection: destinations ───────────────────────────────────────
    match /destinations/{destinationId} {
      allow read: if true;
      // admin-v2 belum pakai Firebase Auth admin role (masih password gate
      // client-side), jadi belum bisa isAdmin()-gated. Minimal butuh login.
      allow create, update, delete: if isAuth();
    }

    // ── Collection: questions ──────────────────────────────────────────
    match /questions/{questionId} {
      // Active approved questions are public read; admin sees all
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Collection: users ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true; // public profile (displayName, photoURL, stats)
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Collection: rooms ──────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if true; // lobby browsing
      allow create: if isAuth();
      // Selain participant/admin, izinin user nambahin dirinya sendiri ke
      // players map kalau belum jadi participant (join room baru). Pakai
      // hasPlayer() biar aman baik pas field `players` belum ada sama
      // sekali maupun pas mapnya masih kosong.
      allow update: if isRoomParticipant(roomId)
        || isAdmin()
        || (isAuth()
            && !hasPlayer(resource.data, request.auth.uid)
            && hasPlayer(request.resource.data, request.auth.uid));
      allow delete: if isAdmin();

      // ── Subcollection: chat ──────────────────────────────────────────
      match /chat/{messageId} {
        allow read: if isRoomParticipant(roomId);
        allow create: if isRoomParticipant(roomId);
        allow update, delete: if false;
      }
    }

    // ── Collection: gameStates ─────────────────────────────────────────
    match /gameStates/{gameId} {
      allow read: if isRoomParticipant(gameId);
      allow create, update: if isRoomParticipant(gameId) || isAdmin();
      allow delete: if false; // never delete, only overwrite
    }

    // ── Collection: gameResults ────────────────────────────────────────
    match /gameResults/{resultId} {
      allow read: if isAuth(); // any logged-in user can view results
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Collection: adminLogs ──────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // append-only audit log
    }

    // ── Collection: informationItems ───────────────────────────────────
    match /informationItems/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
